# ============================================================
#  KANBAN ACADÊMICO — Variáveis de Ambiente
#  Copie este arquivo para .env e preencha os valores reais
# ============================================================

# --- Servidor ---
PORT=3000
NODE_ENV=development

# --- Banco de Dados PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kanban_academico
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui

# --- JWT (JSON Web Token) ---
JWT_SECRET=troque_por_uma_string_longa_e_aleatoria_aqui
JWT_EXPIRES_IN=8h

# --- bcrypt ---
BCRYPT_ROUNDS=10
